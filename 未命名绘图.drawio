        <mxCell id="vFRQLZqHes9Lza9tFrGw-1016" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;strong style=&quot;font-weight: 600; color: rgb(15, 17, 21); font-family: quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Open Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span class=&quot;&quot;&gt;Persistent Voxel Memory for Geometrically Consistent Triangle Splatting&lt;/span&gt;&lt;/strong&gt;&lt;div&gt;&lt;strong style=&quot;font-weight: 600; color: rgb(15, 17, 21); font-family: quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Open Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span class=&quot;&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;span class=&quot;&quot;&gt;“Slow World-Space Geometric Memory for Triangle Splatting”&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="750" x="-550" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="vFRQLZqHes9Lza9tFrGw-1018" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=39;fontColor=#CC0000;fontStyle=1;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" value="&lt;h3 style=&quot;font-style: normal; font-variant: normal; font-size-adjust: none; font-language-override: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-stretch: normal; font-size: 20px; line-height: 30px; font-family: quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Open Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; margin: 32px 0px 16px; color: rgb(15, 17, 21); text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span class=&quot;&quot;&gt;1、&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-family: &amp;quot;Trebuchet MS&amp;quot;, Verdana, Arial, sans-serif; font-size: 16px; font-weight: 400; background-color: transparent; text-align: center;&quot;&gt;校正深度引导 （法线？）&lt;/span&gt;&lt;/h3&gt;&lt;h3 style=&quot;font-style: normal; font-variant: normal; font-size-adjust: none; font-language-override: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-stretch: normal; font-size: 20px; line-height: 30px; font-family: quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Open Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; margin: 32px 0px 16px; color: rgb(15, 17, 21); text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); color: light-dark(rgb(15, 17, 21), rgb(222, 223, 227));&quot;&gt;2、顶点信任域&lt;/span&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="80" width="230" x="10" y="3240" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;gantt\n    title 损失函数 L 训练时序图\n    dateFormat X\n    axisFormat %s步\n\n    section L_rgb (颜色损失)\n    始终开启                :active, l1, 0, 30000\n\n    section L_ssim (结构损失)\n    始终开启                :active, l2, 0, 30000\n\n    section L_corrected_depth (校正深度损失)\n    等待体素预热            :l3a, 0, 8000\n    开启                    :active, l3b, 8000, 30000\n\n    section L_heldout_innovation (留出创新损失)\n    未启用                  :l4a, 0, 20000\n    开启                    :active, l4b, 20000, 30000\n\n    section L_trust (信任域损失)\n    未启用                  :l5a, 0, 25000\n    可选实验                :l5b, 25000, 30000&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vFRQLZqHes9Lza9tFrGw-1020">
