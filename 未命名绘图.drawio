        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart LR\n    subgraph Input\n        I[无人机图像]\n    end\n\n    subgraph BranchA[\&quot;分支A：三角形渲染\&quot;]\n        A_T[三角形参数]\n        A_R[渲染器]\n        A_C[RGB图]\n        A_D[深度图]\n    end\n\n    subgraph BranchB[\&quot;分支B：体素几何\&quot;]\n        B_F[体素融合]\n        B_V[TSDF体素网格]\n        B_Q[表面查询]\n        B_D[体素深度图]\n    end\n\n    subgraph Loss[\&quot;损失与更新\&quot;]\n        L[损失函数]\n        G[梯度下降]\n    end\n\n    I --&gt; A_R\n    A_T --&gt; A_R\n    A_R --&gt; A_C\n    A_R --&gt; A_D\n\n    A_D --&gt; B_F\n    B_F --&gt; B_V\n    B_V --&gt; B_Q\n    B_Q --&gt; B_D\n\n    A_C --&gt; L\n    A_D --&gt; L\n    B_D --&gt; L\n    L --&gt; G\n    G --&gt;|更新| A_T\n\n    A_D -.-&gt;|A→B 引导| B_F\n    B_D -.-&gt;|B→A 引导| L&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="I2-MLwSUc6GrMuPYaOo3-126">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
