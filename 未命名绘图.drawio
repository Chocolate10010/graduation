        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;gantt\n    title Voxel-guided Triangle Splatting 训练时序图\n    dateFormat X\n    axisFormat %s步\n\n    section 三角形参数θ\n    RGB预热优化           :active, a1, 0, 7000\n    全损失优化(含几何)     :active, a2, 8000, 30000\n\n    section 体素状态F_online\n    初始化                 :done, b0, 0, 1\n    深度融合更新(接收深度)  :b1, 7000, 30000\n    定期发布快照           :milestone, b2, 8000, 0\n\n    section 体素快照F_slow\n    空状态                 :c0, 0, 7000\n    快照生成(每N步)        :c1, 8000, 30000\n    射线查询D_slow          :c2, 8000, 30000\n\n    section 损失函数\n    L_rgb                  :d1, 0, 30000\n    L_screen               :d2, 0, 30000\n    L_corrected_depth      :d3, 8000, 30000\n    L_heldout_innovation   :d4, 20000, 30000\n\n    section 相机分组\n    全部训练视图           :e0, 0, 20000\n    刷新组+留出组          :e1, 20000, 30000\n\n    section 置信度控制\n    C_obs (观测可靠性)     :f1, 7000, 30000\n    C_stability (稳定性)   :f2, 7000, 30000\n    C_innovation (创新度)  :f3, 20000, 30000\n    C_guidance_base (门)   :f4, 8000, 30000\n\n    section 消融实验\n    世界信任区域           :g1, 25000, 30000\n    拓扑图只读诊断         :g2, 28000, 30000&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vFRQLZqHes9Lza9tFrGw-895">
