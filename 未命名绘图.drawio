        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph Camera[\&quot;相机参数\&quot;]\n        K1[内参 K]\n        R1[旋转 R]\n        T1[平移 t]\n    end\n\n    subgraph Tri[\&quot;3D三角形\&quot;]\n        T3D[三个顶点 v₁,v₂,v₃]\n    end\n\n    subgraph Project[\&quot;投影\&quot;]\n        PROJ[\&quot;q_i = K(R·v_i + t)\&quot;]\n        T2D[2D三角形]\n    end\n\n    subgraph Window[\&quot;窗口函数\&quot;]\n        SDF[计算符号距离场 φ(p)]\n        INNER[找到内心 s]\n        WIN[I(p)=ReLU(φ(p)/φ(s))^σ]\n    end\n\n    subgraph Render[\&quot;渲染\&quot;]\n        BLEND[深度顺序混合]\n        OUT[RGB图 + 深度图]\n    end\n\n    T3D --&gt; PROJ\n    K1 --&gt; PROJ\n    R1 --&gt; PROJ\n    T1 --&gt; PROJ\n    PROJ --&gt; T2D\n    T2D --&gt; SDF\n    SDF --&gt; INNER\n    INNER --&gt; WIN\n    WIN --&gt; BLEND\n    BLEND --&gt; OUT&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vFRQLZqHes9Lza9tFrGw-4">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="对每个像素" mermaidId="n:Render" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="渲染" id="vFRQLZqHes9Lza9tFrGw-21">
          <mxCell parent="vFRQLZqHes9Lza9tFrGw-4" style="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" vertex="1">
