        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph S0[\&quot;步骤0：初始化\&quot;]\n        S0_1[\&quot;COLMAP → 相机参数 {K_i,R_i,t_i} + 稀疏点云 P\&quot;]\n        S0_2[\&quot;从点云生成初始三角形：v_j,k = p_j + k·d·u_k\&quot;]\n        S0_3[\&quot;初始化体素网格：TSDF=0, weight=0, state=unknown\&quot;]\n    end\n\n    subgraph S1[\&quot;步骤1：分支A渲染（三角形→图像）\&quot;]\n        S1_1[\&quot;3D→2D投影：q_i = K(R·v_i + t)\&quot;]\n        S1_2[\&quot;计算符号距离场：φ(p) = max_i (n_i·p + d_i)\&quot;]\n        S1_3[\&quot;找到内心：s = argmin φ(p)\&quot;]\n        S1_4[\&quot;窗口函数：I(p) = ReLU(φ(p)/φ(s))^σ\&quot;]\n        S1_5[\&quot;深度顺序混合：C(p) = Σ c_i·o_i·I_i(p)·Π(1-o_j·I_j(p))\&quot;]\n        S1_6[\&quot;输出：C_render（RGB图）+ D_render（深度图）\&quot;]\n    end\n\n    subgraph S2[\&quot;步骤2：体素融合（A→B）\&quot;]\n        S2_1[\&quot;深度→世界坐标：P_world = R^T·(K^{-1}·[u,v,1]^T·D(u,v) - t)\&quot;]\n        S2_2[\&quot;世界坐标→体素索引：idx = floor((P_world - V_origin)/V_size)\&quot;]\n        S2_3[\&quot;计算TSDF：tsdf = clamp(sdf/truncation, -1, 1)\&quot;]\n        S2_4[\&quot;加权平均更新：tsdf_new = (tsdf_old·w_old + tsdf_obs·w_obs)/(w_old+w_obs)\&quot;]\n        S2_5[\&quot;输出：更新后的体素网格 V_updated\&quot;]\n    end\n\n    subgraph S3[\&quot;步骤3：体素查询（B→A）\&quot;]\n        S3_1[\&quot;沿射线方向采样：P_k = ray_origin + λ_k·ray_direction\&quot;]\n        S3_2[\&quot;找TSDF=0的零交叉点：λ_zero = λ_k - TSDF(P_k)·(λ_k+1-λ_k)/(TSDF(P_k+1)-TSDF(P_k))\&quot;]\n        S3_3[\&quot;输出：体素深度图 D_slow\&quot;]\n    end\n\n    subgraph S4[\&quot;步骤4：计算损失\&quot;]\n        S4_1[\&quot;RGB损失：L_rgb = (1-λ)·L1 + λ·L_D-SSIM\&quot;]\n        S4_2[\&quot;深度一致性损失：L_corrected = Σ||D_render-D_slow||² / N_valid\&quot;]\n        S4_3[\&quot;不透明度正则：L_opacity = (1/N)Σ(0.25 - (o_i-0.5)²)\&quot;]\n        S4_4[\&quot;尺寸正则：L_size = Σ 2/||(v1-v0)×(v2-v0)||₂\&quot;]\n        S4_5[\&quot;总损失：L_total = L_rgb + β_c·L_corrected + β_o·L_opacity + β_s·L_size\&quot;]\n    end\n\n    subgraph S5[\&quot;步骤5：反向传播更新\&quot;]\n        S5_1[\&quot;计算梯度：∂L_total/∂v, ∂L_total/∂c, ∂L_total/∂o, ∂L_total/∂σ\&quot;]\n        S5_2[\&quot;更新顶点：v ← v - η_v·∂L/∂v\&quot;]\n        S5_3[\&quot;更新颜色：c ← c - η_c·∂L/∂c\&quot;]\n        S5_4[\&quot;更新不透明度：o ← o - η_o·∂L/∂o\&quot;]\n        S5_5[\&quot;更新光滑度：σ ← σ - η_σ·∂L/∂σ\&quot;]\n    end\n\n    subgraph S6[\&quot;步骤6：硬化与导出\&quot;]\n        S6_1[\&quot;退火：σ_anneal(t) = σ_initial + (σ_final-σ_initial)·t/T_anneal\&quot;]\n        S6_2[\&quot;剪掉低不透明度三角形\&quot;]\n        S6_3[\&quot;导出网格：.ply / .glb\&quot;]\n    end\n\n    S0_1 --&gt; S0_2\n    S0_1 --&gt; S0_3\n    S0_2 --&gt; S1_1\n    S0_3 --&gt; S2_1\n\n    S1_1 --&gt; S1_2 --&gt; S1_3 --&gt; S1_4 --&gt; S1_5 --&gt; S1_6\n\n    S1_6 --&gt; S2_1\n    S2_1 --&gt; S2_2 --&gt; S2_3 --&gt; S2_4 --&gt; S2_5\n\n    S2_5 --&gt; S3_1\n    S3_1 --&gt; S3_2 --&gt; S3_3\n\n    S1_6 --&gt; S4_1\n    S3_3 --&gt; S4_2\n    S1_6 --&gt; S4_2\n    S4_1 --&gt; S4_5\n    S4_2 --&gt; S4_5\n    S4_3 --&gt; S4_5\n    S4_4 --&gt; S4_5\n\n    S4_5 --&gt; S5_1\n    S5_1 --&gt; S5_2\n    S5_1 --&gt; S5_3\n    S5_1 --&gt; S5_4\n    S5_1 --&gt; S5_5\n\n    S5_2 --&gt; S6_1\n    S5_3 --&gt; S6_1\n    S5_4 --&gt; S6_1\n    S5_5 --&gt; S6_1\n    S6_1 --&gt; S6_2 --&gt; S6_3&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="I2-MLwSUc6GrMuPYaOo3-53">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
