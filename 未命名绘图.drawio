        <UserObject label="计算符号距离场：φ(p) = max_i (n_i·p + d_i)" mermaidId="n:S1_2" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="计算符号距离场：φ(p) = max_i (n_i·p + d_i)" id="I2-MLwSUc6GrMuPYaOo3-62">
