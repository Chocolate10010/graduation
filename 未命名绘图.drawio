        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph Input[\&quot;输入数据\&quot;]\n        A[多视角图像]\n        B[COLMAP 标定]\n    end\n\n    subgraph Init[\&quot;初始化 (3.3 节)\&quot;]\n        C[SfM 稀疏点云]\n        D[为每个点生成一个&lt;br&gt;近似等边随机朝向的三角形]\n        E[初始化参数:&lt;br&gt;顶点、颜色SH、α、σ]\n    end\n\n    subgraph Optim[\&quot;训练循环 (3.1/3.2/3.3 节)\&quot;]\n        subgraph Render[\&quot;前向渲染 (3.1 节)\&quot;]\n            F[3D 三角形投影到 2D]\n            G[计算符号距离场 φ(p)]\n            H[计算窗口函数&lt;br&gt;I(p)=ReLU(φ(p)/φ(s))^σ]\n            I[按深度顺序混合&lt;br&gt;C(p)=Σ c·α·I·Π(1-α·I)]\n            J[输出: RGB图 + 深度图]\n        end\n\n        subgraph Loss[\&quot;损失计算 (3.3 节)\&quot;]\n            K[光度损失: L₁ + D-SSIM]\n            L[正则化损失: L₀+Ld+Ln+Ls]\n            M[总损失: L = ...]\n        end\n\n        subgraph Update[\&quot;参数更新 (3.3 节)\&quot;]\n            N[反向传播梯度]\n            O[更新顶点、颜色、α、σ]\n        end\n\n        subgraph Density[\&quot;密度控制 (3.2 节)\&quot;]\n            P[剪枝: 移除低贡献&lt;br&gt;和单视图过拟合三角形]\n            Q[密化: MCMC采样&lt;br&gt;低σ区域中点细分]\n        end\n    end\n\n    subgraph Output[\&quot;输出\&quot;]\n        R[收敛的三角形汤]\n        S[导出 .ply / .obj]\n        T[游戏引擎 / 传统渲染器]\n    end\n\n    A --&gt; C\n    B --&gt; C\n    C --&gt; D --&gt; E\n    E --&gt; F\n    F --&gt; G --&gt; H --&gt; I --&gt; J\n    J --&gt; K\n    K --&gt; M\n    L --&gt; M\n    M --&gt; N --&gt; O\n    O --&gt;|每N步| P\n    P --&gt; Q\n    Q --&gt;|继续迭代| F\n    O --&gt;|训练完成| R\n    R --&gt; S --&gt; T&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="I2-MLwSUc6GrMuPYaOo3-157">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
