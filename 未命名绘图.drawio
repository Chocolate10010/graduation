        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;gantt\n    title GSDF训练时序图\n    dateFormat X\n    axisFormat %s轮\n\n    section GS分支\n    GS单独训练           :a1, 0, 15000\n    GS联合训练           :a2, 15000, 45000\n\n    section SDF分支\n    SDF预热训练(无GS引导) :b1, 15000, 17000\n    SDF联合训练(有GS引导) :b2, 17000, 45000\n\n    section 三大机制\n    机制1: 深度引导采样    :c1, 17000, 45000\n    机制2: 几何感知密度控制 :c2, 15000, 45000\n    机制3: 双向几何监督    :c3, 17000, 45000\n\n    section 损失\n    L_g (GS损失)         :d1, 0, 45000\n    L_s (SDF损失)        :d2, 15000, 45000\n    L_mutual (一致性损失) :d3, 17000, 45000\n\n    section 哈希网格\n    粗层(4-8层)激活      :e1, 15000, 25000\n    精细层逐级激活        :e2, 25000, 45000&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vFRQLZqHes9Lza9tFrGw-687">
