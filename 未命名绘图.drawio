            <mxGeometry height="54" width="318" x="94" y="357" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="深度顺序混合：C(p) = Σ c_i·o_i·I_i(p)·Π(1-o_j·I_j(p))" mermaidId="n:S1_5" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="深度顺序混合：C(p) = Σ c_i·o_i·I_i(p)·Π(1-o_j·I_j(p))" id="I2-MLwSUc6GrMuPYaOo3-65">
