        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph 输入\n        A[2D三角形 T₂D]\n        B[像素 p]\n    end\n\n    subgraph SDF[\&quot;符号距离场计算\&quot;]\n        C[\&quot;L_i(p) = n_i·p + d_i, i=1,2,3\&quot;]\n        D[\&quot;φ(p) = max(L₁, L₂, L₃)\&quot;]\n        E[找到内心 s = argmin φ(p)]\n    end\n\n    subgraph Window[\&quot;窗口函数\&quot;]\n        F[\&quot;I(p) = ReLU(φ(p)/φ(s))^σ\&quot;]\n        G[\&quot;I(p) ∈ [0,1]\&quot;]\n    end\n\n    subgraph 性质\n        H[\&quot;内部：I(p) &gt; 0\&quot;]\n        I[\&quot;边界：I(p) = 0\&quot;]\n        J[\&quot;外部：I(p) = 0（ReLU保证）\&quot;]\n        K[\&quot;内心：I(s) = 1\&quot;]\n    end\n\n    subgraph 输出\n        L[\&quot;软不透明度值 I(p)\&quot;]\n    end\n\n    A --&gt; C\n    B --&gt; C\n    C --&gt; D\n    D --&gt; E\n    E --&gt; F\n    D --&gt; F\n    F --&gt; G\n    G --&gt; H\n    G --&gt; I\n    G --&gt; J\n    G --&gt; K\n    H --&gt; L\n    I --&gt; L\n    J --&gt; L\n    K --&gt; L&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vFRQLZqHes9Lza9tFrGw-31">
