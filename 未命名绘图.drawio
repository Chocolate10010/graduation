        <UserObject label="TriangleModel&amp;nbsp;&lt;div&gt;优化&lt;/div&gt;" mermaidId="n:Update" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="参数更新 (3.3 节)" id="LEiKnLwLYeOuBzCYz1zt-811">
          <mxCell parent="1" style="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=middle;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;pointerEvents=0;align=center;resizable=1;gradientColor=none;container=0;movable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" vertex="1">
            <mxGeometry height="70" width="140" x="510" y="6270" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="LEiKnLwLYeOuBzCYz1zt-812" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;rounded=0;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=19;resizable=1;fillColor=default;" value="&lt;div&gt;for iteration in range(first_iter, opt.iterations + 1):&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 1️⃣ 相机选择&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; viewpoint_cam = viewpoint_stack.pop(random_index)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 2️⃣ 渲染&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; render_pkg = render(viewpoint_cam, triangles, pipe, bg)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; image = render_pkg[&quot;render&quot;]&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; depth_map = render_pkg[&quot;surf_depth&quot;]&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 3️⃣ 计算Loss&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # - 图像Loss: L_rgb + L_opacity + L_normal + L_distortion&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # - 多视图一致性Loss: L_mv&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # - 体素引导Loss: L_corrected_depth + L_voxel_position + L_voxel_normal&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 4️⃣ 体素场刷新 (每voxel_refresh_interval次迭代)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if can_refresh and iteration % opt.voxel_refresh_interval == 0:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; fused_points = []&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; for refresh_camera in refresh_cameras:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # 从渲染深度提取点&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; points = pixels_to_world(refresh_camera, pixels, depth)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; fused_points.append(points)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # 融合到体素场&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; voxel_fusion.fuse_tsdf_samples(fused_points, ...)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # 发布教师模型（稳定后）&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if stability[&quot;stable&quot;]:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; voxel_state.publish_teacher(iteration)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 5️⃣ 反向传播&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; loss.backward()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 6️⃣ 三角形拓扑更新&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if iteration % opt.densification_interval == 0:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; triangles.add_new_gs(dead_mask=dead_mask, selection_mask=split_mask)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # 7️⃣ 优化器步骤&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; triangles.optimizer.step()&lt;/div&gt;" vertex="1">
          <mxGeometry height="930" width="740" x="-380" y="6430" as="geometry" />
        </mxCell>
