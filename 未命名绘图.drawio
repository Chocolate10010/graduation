        <UserObject label="从点云生成初始三角形：v_j,k = p_j + k·d·u_k" mermaidId="n:S0_2" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="从点云生成初始三角形：v_j,k = p_j + k·d·u_k" id="I2-MLwSUc6GrMuPYaOo3-56">
