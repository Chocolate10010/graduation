        <UserObject label="步骤1：分支A渲染（三角形→图像）" mermaidId="n:S1" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="步骤1：分支A渲染（三角形→图像）" id="I2-MLwSUc6GrMuPYaOo3-60">
