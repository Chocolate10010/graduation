        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph S1[\&quot;步骤0：初始化\&quot;]\n        A[多视角图像 + COLMAP标定]\n        B[SfM稀疏点云]\n        C[生成初始三角形]\n        D[初始化参数：顶点、颜色SH、α、σ]\n    end\n\n    subgraph S2[\&quot;步骤1：分支A渲染\&quot;]\n        E[3D→2D投影]\n        F[计算符号距离场 φ(p)]\n        G[窗口函数 I(p)=ReLU(φ(p)/φ(s))^σ]\n        H[深度顺序混合]\n        I[输出RGB图 + 深度图]\n    end\n\n    subgraph S3[\&quot;步骤2：体素融合\&quot;]\n        J[深度→世界坐标]\n        K[体素加权平均融合]\n        L[更新TSDF体素网格]\n    end\n\n    subgraph S4[\&quot;步骤3：体素查询\&quot;]\n        M[沿射线采样]\n        N[找TSDF=0零交叉点]\n        O[输出体素深度图 D_slow]\n    end\n\n    subgraph S5[\&quot;步骤4：损失计算\&quot;]\n        P[RGB损失 L_rgb]\n        Q[深度一致性损失 L_corrected]\n        R[正则化损失 L_o+L_d+L_n+L_s]\n        S[总损失 L_total]\n    end\n\n    subgraph S6[\&quot;步骤5：参数更新\&quot;]\n        T[反向传播梯度]\n        U[更新顶点/颜色/α/σ]\n    end\n\n    subgraph S7[\&quot;步骤6：密度控制\&quot;]\n        V[剪枝低贡献三角形]\n        W[密化低σ区域]\n    end\n\n    subgraph S8[\&quot;步骤7：硬化与导出\&quot;]\n        X[退火σ→σ_final]\n        Y[剪掉低α三角形]\n        Z[导出PLY/GLB网格]\n    end\n\n    A --&gt; B\n    B --&gt; C\n    C --&gt; D\n    D --&gt; E\n\n    E --&gt; F\n    F --&gt; G\n    G --&gt; H\n    H --&gt; I\n\n    I --&gt; J\n    J --&gt; K\n    K --&gt; L\n\n    L --&gt; M\n    M --&gt; N\n    N --&gt; O\n\n    I --&gt; P\n    O --&gt; Q\n    I --&gt; Q\n    P --&gt; S\n    Q --&gt; S\n    R --&gt; S\n\n    S --&gt; T\n    T --&gt; U\n\n    U --&gt; V\n    V --&gt; W\n    W --&gt; E\n\n    U --&gt; X\n    X --&gt; Y\n    Y --&gt; Z&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="I2-MLwSUc6GrMuPYaOo3-206">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
