            <mxGeometry height="54" width="374" x="66" y="149" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="找到内心：s = argmin φ(p)" mermaidId="n:S1_3" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="找到内心：s = argmin φ(p)" id="I2-MLwSUc6GrMuPYaOo3-63">
          <mxCell parent="I2-MLwSUc6GrMuPYaOo3-60" style="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" vertex="1">
            <mxGeometry height="54" width="251" x="127" y="253" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="窗口函数：I(p) = ReLU(φ(p)/φ(s))^σ" mermaidId="n:S1_4" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="窗口函数：I(p) = ReLU(φ(p)/φ(s))^σ" id="I2-MLwSUc6GrMuPYaOo3-64">
